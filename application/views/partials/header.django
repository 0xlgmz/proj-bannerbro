<!DOCTYPE html>
<html>
<html lang="en" xmlns="http://www.w3.org/1999/html">

<head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <link rel="icon" type="image/png" href="/public/favicon-32x32.png" />
        <link href="/static/style.css" rel="stylesheet">

        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
                integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
                crossorigin="anonymous" referrerpolicy="no-referrer" />

        <link rel="stylesheet" type="text/css" href="https://unpkg.com/notie/dist/notie.min.css">
        <script src="https://unpkg.com/htmx.org@1.6.1"></script>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
                integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
                crossorigin="anonymous">

</head>

<body class="d-flex flex-column min-vh-100" data-bs-theme="dark">

        <header class="text-bg-dark">
                <div>
                        <nav class="navbar bg-dark border-bottom border-body" data-bs-theme="dark">
                                <div class="container-fluid">
                                        <ul class="nav justify-content-start">
                                                <li class="nav-item">
                                                        <a id="tagline-nav" class="nav-link disabled" aria-disabled="true">
                                                        <img src="https://yt3.googleusercontent.com/oO-sFenv1PiLt0-5zmd0Vq04MuWUPYuAWKkvTnChzZmc6IsN8TWy9gqum41cZ8nSG9wQJyG7VOo=s160-c-k-c0x00ffffff-no-rj"
                                                                alt="Logo" width="32" height="32" id="circle-img"
                                                                class="d-inline-block align-text-center"> BannerBro
                                                        </a>
                                                </li>
                                        </ul>
                                        <ul class="nav justify-content-center">
                                                <li class="nav-item">
                                                        <a id="tagline-nav" class="nav-link disabled"
                                                                aria-disabled="true">Build banners quick and easily in one swift motion!</a>
                                                </li>
                                        </ul>

                                        <ul class="nav justify-content-end">
                                                <li class="nav-item">
                                                        <a class="nav-link" href="#" role="button" aria-expanded="false">
                                                                <button type="button" class="btn btn-primary position-relative" onclick="toggleTheme()">
                                                                        <div id="theme-light" style="display: none;">
                                                                                <i class="fa-regular fa-moon"></i>
                                                                        </div>
                                                                        <div id="theme-dark" style="display: none;">
                                                                                <i class="fa-regular fa-sun"></i>
                                                                        </div>
                                                                </button>
                                                        </a> 
                                                </li>
                                                <li class="nav-item">
                                                        <a class="nav-link" href="#" role="button" aria-expanded="false" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                                                        <button type="button" class="btn btn-primary position-relative">
                                                                <i class="fas fa-bell"></i>
                                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                                                  1
                                                                        <span class="visually-hidden">unread messages</span>
                                                                </span>
                                                        </button>
                                                        </a>
                                                </li>
                                        </ul>
                                </div>
                        </nav>
                </div>
        </header>  

        <!-- Modal -->
        <div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"">
                        <div class="modal-content vh-100">
                                <div class="modal-header">
                                        <h1 class="modal-title fs-5" id="staticBackdropLabel">Notification Center</h1>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                        Hello
                                </div>
                                <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                </div>
                        </div>
                </div>
        </div>